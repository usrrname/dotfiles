#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Check for exposed secrets before linting
SECRETS_PATTERN="-----BEGIN.*PRIVATE KEY-----|AKIA[0-9A-Z]{16}|ghp_[0-9a-zA-Z]{36}|gho_[0-9a-zA-Z]{36}|ghu_[0-9a-zA-Z]{36}|ghs_[0-9a-zA-Z]{36}|ghr_[0-9a-zA-Z]{36}|xox[baprs]-[0-9a-zA-Z]{10,48}|sk-[0-9a-zA-Z]{48}|sq0[a-z]-[0-9a-zA-Z]{22,43}|AIza[0-9A-Za-z_-]{35}|password\s*[:=]\s*['\"][^'\"]{8,}['\"]|aws_secret_access_key"

SKIP_PATTERN="\.gitignore|\.gitmodules|\.env\.schema|README|\.md$|/tests?/"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)
VIOLATIONS=0

for file in $STAGED_FILES; do
	case "$file" in
		*.png|*.jpg|*.jpeg|*.gif|*.ico|*.woff|*.woff2|*.ttf|*.eot) continue ;;
	esac
	if echo "$file" | grep -qE "$SKIP_PATTERN"; then continue; fi

	content=$(git show ":$file" 2>/dev/null)
	if [ -z "$content" ] && [ -f "$file" ]; then content=$(cat "$file"); fi

	if [ -n "$content" ]; then
		if echo "$content" | grep -qE "$SECRETS_PATTERN" 2>/dev/null; then
			echo "ERROR: Potential secret found in $file"
			VIOLATIONS=$((VIOLATIONS + 1))
		fi
	fi
done

if [ $VIOLATIONS -gt 0 ]; then
	echo "Secrets detected. Aborting commit. Use --no-verify to skip."
	exit 1
fi

npx --no-install lint-staged
