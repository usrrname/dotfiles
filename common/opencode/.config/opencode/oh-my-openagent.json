{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "agents": {
    "hephaestus": {
      "model": "opencode-go/kimi-k2.7",
      "permission": {
        "edit": "allow",
        "bash": "ask"
      }
    },
    "oracle": {
      "model": "opencode-go/qwen3.7-max",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "librarian": {
      "model": "opencode-go/minimax-m2.7",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "deny"
      }
    },
    "explore": {
      "model": "opencode-go/minimax-m2.7",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "deny"
      }
    },
    "multimodal-looker": {
      "model": "opencode-go/minimax-m2.7"
    },
    "prometheus": {
      "model": "opencode-go/deepseek-v4-pro"
    },
    "metis": {
      "model": "opencode-go/glm-5",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "momus": {
      "model": "opencode-go/glm-5",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "atlas": {
      "model": "opencode-go/kimi-k2.7"
    },
    "sisyphus": {
      "model": "opencode-go/kimi-k2.7",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "task": "allow"
      }
    },
    "sisyphus-junior": {
      "model": "opencode-go/glm-5"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode-go/minimax-m2.7",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "opencode-go/qwen3.7-max",
      "variant": "xhigh"
    },
    "deep": {
      "model": "opencode-go/qwen3.7-max",
      "variant": "medium"
    },
    "artistry": {
      "model": "opencode-go/minimax-m2.7",
      "variant": "high"
    },
    "quick": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "unspecified-low": {
      "model": "opencode-go/minimax-m2.7"
    },
    "unspecified-high": {
      "model": "opencode-go/glm-5.1",
      "variant": "max"
    },
    "writing": {
      "model": "opencode-go/qwen3.7-plus"
    }
  }
}
