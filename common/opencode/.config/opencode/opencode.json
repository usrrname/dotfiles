{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "instructions": [
    "AGENTS.md",
    "$HOME/.dotfiles/common/opencode/.config/opencode/skills/commit-conventions.md"
  ],
  "mcp": {
    "varlock-docs-mcp": {
      "type": "remote",
      "url": "https://docs.mcp.varlock.dev/mcp",
      "enabled": true
    }
  },
  "plugin": [
    "opencode-openmemory@latest",
    "oh-my-opencode@latest",
    "opencode-speech-to-text@latest"
  ],
  "default_agent": "build"
}
