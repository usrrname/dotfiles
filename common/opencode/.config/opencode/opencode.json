{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "instructions": [
    "AGENTS.md",
    "$HOME/.config/opencode/skills/agent-communication.md"
  ],
  "mcp": {
    "varlock-docs-mcp": {
      "type": "remote",
      "url": "https://docs.mcp.varlock.dev/mcp",
      "enabled": false
    }
  },
  "plugin": [
    "opencode-openmemory@latest",
    "oh-my-opencode@latest"
  ],
  "skills": {
    "paths": [
      "./skills/**"
    ]
  },
  "default_agent": "build"
}
